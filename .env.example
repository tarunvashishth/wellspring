# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wellspring:wellspring@localhost:5432/wellspring
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5432/wellspring

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-secret-for-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── AWS / MinIO ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_BUCKET=wellspring-media
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT=http://localhost:9000   # remove in production

# ─── Limits ──────────────────────────────────────────────────────────────────
PRISMA_POOL_MAX=10
MAX_PROGRAMS_PER_CREATOR=50
MAX_SESSIONS_PER_PROGRAM=500
UPLOAD_MAX_BYTES=524288000          # 500 MB
IMPORT_TX_TIMEOUT_MS=120000
IMPORT_STUCK_PENDING_MS=300000
IMPORT_STUCK_PROCESSING_MS=600000

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
